# Copy to server/.env (which is gitignored) and fill in your key.
# If you leave OPENAI_API_KEY blank, the proxy falls back to a local
# OpenAI-compatible server at http://127.0.0.1:5052 (used in Hallie's
# setup for a local Qwen). For Jon: easiest is to set OPENAI_API_KEY.

OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
PORT=8787
